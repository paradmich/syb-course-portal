# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Better Auth
# Generate secret: openssl rand -base64 32
# ─────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Database
# Local dev: SQLite (no config needed — db.sqlite is created automatically)
# Production: add a Postgres URL from Neon (neon.tech) or Supabase (supabase.com)
# and swap the database adapter in lib/auth.ts
# ─────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host/dbname

# ─────────────────────────────────────────────
# Stripe
# Get from: stripe.com → Developers → API keys
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --forward-to localhost:3000/api/webhooks/stripe

# Stripe Price IDs (create in Stripe Dashboard → Products → Add product)
# Leave blank to use dynamic pricing (works without Stripe setup for dev)
NEXT_PUBLIC_STRIPE_PRICE_CHANNEL_VOICE=
NEXT_PUBLIC_STRIPE_PRICE_SIGNATURE_COURSE=
NEXT_PUBLIC_STRIPE_PRICE_VIRTUAL_SUMMIT=
NEXT_PUBLIC_STRIPE_PRICE_HAWAII_RETREAT=
NEXT_PUBLIC_STRIPE_PRICE_SANTAFE_RETREAT=
